@using ResQMe.ViewModels.Animal
@using ResQMe.Data.Models.Enums
@model AnimalFilterViewModel

@if (TempData["AdminSuccess"] != null)
{
    <div class="alert alert-success">@TempData["AdminSuccess"]</div>
}

<div class="row mt-3">
    <!-- Sidebar Filters -->
    <div class="col-md-3">
        <form method="get" id="filterForm">
            <div class="filter-card p-3 mb-3">
                <h6 class="fw-bold mb-3" style="color:#7b4f2e;">Filters</h6>

                <!-- Search -->
                <div class="mb-3">
                    <input type="text" name="searchTerm" value="@Model.SearchTerm"
                           placeholder="Name or breed..." class="form-control form-control-sm" />
                </div>

                <div class="accordion" id="filterAccordion">

                    <!-- Species -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(Model.SelectedSpeciesIds.Any() ? "" : "collapsed") py-2" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapseSpecies">
                                Species
                            </button>
                        </h2>
                        <div id="collapseSpecies" class="accordion-collapse collapse @(Model.SelectedSpeciesIds.Any() ? "show" : "")"
                             data-bs-parent="#filterAccordion">
                            <div class="accordion-body py-2">
                                @foreach (var species in Model.AvailableSpecies)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="selectedSpeciesIds"
                                               value="@species.Id" id="species_@species.Id"
                                               @(Model.SelectedSpeciesIds.Contains(species.Id) ? "checked" : "") />
                                        <label class="form-check-label" for="species_@species.Id">@species.Name</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Gender -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(Model.SelectedGenders.Any() ? "" : "collapsed") py-2" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapseGender">
                                Gender
                            </button>
                        </h2>
                        <div id="collapseGender" class="accordion-collapse collapse @(Model.SelectedGenders.Any() ? "show" : "")"
                             data-bs-parent="#filterAccordion">
                            <div class="accordion-body py-2">
                                @foreach (Gender gender in Enum.GetValues(typeof(Gender)))
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="selectedGenders"
                                               value="@((int)gender)" id="gender_@gender"
                                               @(Model.SelectedGenders.Contains(gender) ? "checked" : "") />
                                        <label class="form-check-label" for="gender_@gender">@gender</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Breed Type -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(Model.SelectedBreedTypes.Any() ? "" : "collapsed") py-2" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapseBreedType">
                                Breed Type
                            </button>
                        </h2>
                        <div id="collapseBreedType" class="accordion-collapse collapse @(Model.SelectedBreedTypes.Any() ? "show" : "")"
                             data-bs-parent="#filterAccordion">
                            <div class="accordion-body py-2">
                                @foreach (BreedType breedType in Enum.GetValues(typeof(BreedType)))
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="selectedBreedTypes"
                                               value="@((int)breedType)" id="breedType_@breedType"
                                               @(Model.SelectedBreedTypes.Contains(breedType) ? "checked" : "") />
                                        <label class="form-check-label" for="breedType_@breedType">@breedType</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- City -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(Model.SelectedCities.Any() ? "" : "collapsed") py-2" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapseCity">
                                City
                            </button>
                        </h2>
                        <div id="collapseCity" class="accordion-collapse collapse @(Model.SelectedCities.Any() ? "show" : "")"
                             data-bs-parent="#filterAccordion">
                            <div class="accordion-body py-2">
                                @foreach (var city in Model.AvailableCities)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="selectedCities"
                                               value="@city" id="city_@city"
                                               @(Model.SelectedCities.Contains(city) ? "checked" : "") />
                                        <label class="form-check-label" for="city_@city">@city</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Age -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(Model.SelectedAgeRanges.Any() ? "" : "collapsed") py-2" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapseAge">
                                Age
                            </button>
                        </h2>
                        <div id="collapseAge" class="accordion-collapse collapse @(Model.SelectedAgeRanges.Any() ? "show" : "")"
                             data-bs-parent="#filterAccordion">
                            <div class="accordion-body py-2">
                                @foreach (var range in new[] { "under 1", "1-3", "4-6", "7-9", "10-12", "13-15", "over 15" })
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="selectedAgeRanges"
                                               value="@range" id="age_@range"
                                               @(Model.SelectedAgeRanges.Contains(range) ? "checked" : "") />
                                        <label class="form-check-label" for="age_@range">@range</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(Model.ShowAdopted.HasValue ? "" : "collapsed") py-2" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapseStatus">
                                Status
                            </button>
                        </h2>
                        <div id="collapseStatus" class="accordion-collapse collapse @(Model.ShowAdopted.HasValue ? "show" : "")"
                             data-bs-parent="#filterAccordion">
                            <div class="accordion-body py-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="showAdopted"
                                           value="false" id="statusAvailable"
                                           @(Model.ShowAdopted == false ? "checked" : "") />
                                    <label class="form-check-label" for="statusAvailable">Available</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="showAdopted"
                                           value="true" id="statusAdopted"
                                           @(Model.ShowAdopted == true ? "checked" : "") />
                                    <label class="form-check-label" for="statusAdopted">Adopted</label>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <button type="submit" class="btn btn-primary btn-sm w-100 mt-3 mb-2">Apply Filters</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">Clear All</a>
            </div>
        </form>
    </div>

    <!-- Main Content -->
    <div class="col-md-9">
        <h2 class="mb-3 text-center">Our Animals</h2>

        @if (User.IsInRole("Admin"))
        {
            <a asp-area="Admin" asp-controller="Animal" asp-action="Add"
               asp-route-returnUrl="@Context.Request.QueryString.Value"
               class="btn btn-success mb-3">
                + Add Animal
            </a>
        }

        @if (!Model.Results.Items.Any())
        {
            <div class="alert alert-info">No animals found matching your filters.</div>
        }
        else
        {
            <div class="row">
                @foreach (var animal in Model.Results.Items)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100">
                            <img src="@animal.ImageUrl" class="card-img-top animal-image" />
                            <div class="card-body d-flex flex-column">
                                <h5 class="fw-bold">@animal.Name <small class="text-muted fs-6">(@animal.Age years old)</small></h5>
                                <p class="mb-1"><strong>Gender:</strong> @animal.Gender</p>
                                <p class="mb-1"><strong>Breed:</strong> @animal.BreedDisplay</p>
                                <p class="mb-1"><strong>Species:</strong> @animal.Species</p>
                                <p class="mb-2"><strong>Shelter:</strong> @animal.Shelter</p>
                                @if (animal.IsAdopted)
                                {
                                    <span class="badge bg-danger mb-2">Adopted</span>
                                }
                                else
                                {
                                    <span class="badge bg-success mb-2">Available</span>
                                }
                                <div class="mt-auto d-flex gap-1 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@animal.Id"
                                       asp-route-returnUrl="@(Context.Request.QueryString.Value)"
                                       class="btn btn-primary btn-sm">Details</a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-area="Admin" asp-controller="Animal" asp-action="Edit"
                                           asp-route-id="@animal.Id"
                                           asp-route-returnUrl="@Context.Request.QueryString.Value"
                                           class="btn btn-warning btn-sm">Edit</a>
                                        <a asp-area="Admin" asp-controller="Animal" asp-action="Delete"
                                           asp-route-id="@animal.Id"
                                           asp-route-returnUrl="@Context.Request.QueryString.Value"
                                           class="btn btn-danger btn-sm">Delete</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.Results.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(!Model.Results.HasPreviousPage ? "disabled" : "")">
                            <button type="submit" form="filterForm" name="page" value="1" class="page-link">First</button>
                        </li>
                        @for (int i = 1; i <= Model.Results.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.Results.CurrentPage ? "active" : "")">
                                <button type="submit" form="filterForm" name="page" value="@i" class="page-link">@i</button>
                            </li>
                        }
                        <li class="page-item @(!Model.Results.HasNextPage ? "disabled" : "")">
                            <button type="submit" form="filterForm" name="page" value="@Model.Results.TotalPages" class="page-link">Last</button>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>