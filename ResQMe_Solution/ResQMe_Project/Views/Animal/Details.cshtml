@model ResQMe.ViewModels.Animal.AnimalDetailsViewModel

<div class="container mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-3">@TempData["Success"]</div>
    }

    <div class="mb-3">
        @if (ViewBag.FromShelterId != null)
        {
            <a asp-area="" asp-controller="Shelter" asp-action="Details"
               asp-route-id="@ViewBag.FromShelterId"
               asp-route-returnUrl="@ViewBag.ShelterReturnUrl"
               class="btn btn-outline-secondary btn-sm">
                ← Back to Shelter
            </a>
        }
        else if (ViewBag.ReturnUrl != null && ViewBag.ReturnUrl.ToString().Contains("MyRequests"))
        {
            <a href="@ViewBag.ReturnUrl" class="btn btn-outline-secondary btn-sm">
                ← Back to My Requests
            </a>
        }
        else if (ViewBag.HasActiveFilters == true)
        {
            <a href="@($"/Animal/Index{ViewBag.ReturnUrl}")" class="btn btn-outline-secondary btn-sm">
                ← Back to Filtered Animals
            </a>
        }
        else
        {
            <a href="@($"/Animal/Index{ViewBag.ReturnUrl}")" class="btn btn-outline-secondary btn-sm">
                ← Back to All Animals
            </a>
        }
    </div>

    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("User") && !Model.IsAdopted    
        && ViewBag.HasAlreadyRequested != null && (bool)ViewBag.HasAlreadyRequested)
    {
        <div class="alert alert-warning mb-3">
            You have already submitted an adoption request for this animal.
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded"
                 style="height:420px; width:100%; object-fit:cover;" />
        </div>
        <div class="col-md-6">
            <h2 class="fw-bold">@Model.Name</h2>
            <p>
                <strong>Age:</strong> @Model.Age years<br />
                <strong>Gender:</strong> @Model.Gender<br />
                <strong>Breed:</strong> @Model.BreedDisplay<br />
                <strong>Species:</strong> @Model.Species
            </p>
            @if (Model.IsAdopted)
            {
                <span class="badge bg-danger mb-3">Adopted</span>
            }
            else
            {
                <span class="badge bg-success mb-3">Available for adoption</span>
            }
            <hr />
            <h5>Description</h5>
            <p>@Model.Description</p>
            <hr />
            <h5>Shelter Information</h5>
            <p>
                <strong>Name:</strong> @Model.ShelterName<br />
                <strong>City:</strong> @Model.ShelterCity<br />
                <strong>Address:</strong> @Model.ShelterAddress<br />
                <strong>Phone:</strong> @Model.ShelterPhone<br />
                <strong>Email:</strong> @Model.ShelterEmail
            </p>
            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("User") && !Model.IsAdopted)
            {
                if (ViewBag.HasAlreadyRequested == null || !(bool)ViewBag.HasAlreadyRequested)
                {
                    <a asp-area=""
                       asp-controller="AdoptionRequest"
                       asp-action="Create"
                       asp-route-animalId="@Model.Id"
                       asp-route-returnUrl="@ViewBag.ReturnUrl"
                       asp-route-fromShelterId="@ViewBag.FromShelterId"
                       asp-route-shelterReturnUrl="@ViewBag.ShelterReturnUrl"
                       class="btn btn-success mt-2">
                        🐾 Adopt Me
                    </a>
                }
            }
        </div>
    </div>
</div>