@using ResQMe.ViewModels.Shelter
@using ResQMe.ViewModels.Common
@model PaginatedResultViewModel<ShelterListViewModel>

@if (TempData["AdminSuccess"] != null)
{
    <div class="alert alert-success">@TempData["AdminSuccess"]</div>
}

<div class="row mt-3">
    <!-- Sidebar -->
    <div class="col-md-3">
        <form method="get" id="filterForm">
            <div class="filter-card p-3 mb-3">
                <h6 class="fw-bold mb-3" style="color:#7b4f2e;">Filters</h6>

                <div class="mb-3">
                    <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                           placeholder="Search by name..." class="form-control form-control-sm" />
                </div>

                <div class="accordion" id="shelterFilterAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(((List<string>)ViewBag.SelectedCities).Any() ? "" : "collapsed") py-2"
                                    type="button" data-bs-toggle="collapse" data-bs-target="#collapseCity">
                                City
                            </button>
                        </h2>
                        <div id="collapseCity" class="accordion-collapse collapse @(((List<string>)ViewBag.SelectedCities).Any() ? "show" : "")"
                             data-bs-parent="#shelterFilterAccordion">
                            <div class="accordion-body py-2">
                                @foreach (var city in (IEnumerable<string>)ViewBag.AvailableCities)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="selectedCities"
                                               value="@city" id="city_@city"
                                               @(((List<string>)ViewBag.SelectedCities).Contains(city) ? "checked" : "") />
                                        <label class="form-check-label" for="city_@city">@city</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-sm w-100 mt-3 mb-2">Apply Filters</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">Clear All</a>
            </div>
        </form>
    </div>

    <!-- Main Content -->
    <div class="col-md-9">
        <h2 class="mb-3 text-center">Our Shelters</h2>

        @if (User.IsInRole("Admin"))
        {
            <a asp-area="Admin" asp-controller="Shelter" asp-action="Add"
               asp-route-returnUrl="@Context.Request.QueryString.Value"
               class="btn btn-success mb-3">
                + Add Shelter
            </a>
        }

        @if (!Model.Items.Any())
        {
            <div class="alert alert-info">No shelters found matching your filters.</div>
        }
        else
        {
            <div class="row">
                @foreach (var shelter in Model.Items)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100">
                            <img src="@shelter.ImageUrl" class="card-img-top"
                                 style="height:200px; object-fit:cover;" />
                            <div class="card-body d-flex flex-column">
                                <h5 class="fw-bold">@shelter.Name</h5>
                                <p class="text-muted mb-2">📍 @shelter.City</p>
                                <div class="mt-auto d-flex gap-1 flex-wrap">
                                    <a asp-action="Details" asp-route-id="@shelter.Id"
                                       asp-route-returnUrl="@(Context.Request.QueryString.Value)"
                                       class="btn btn-primary btn-sm">Details</a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-area="Admin" asp-controller="Shelter" asp-action="Edit"
                                           asp-route-id="@shelter.Id"
                                           asp-route-returnUrl="@Context.Request.QueryString.Value"
                                           class="btn btn-warning btn-sm">Edit</a>
                                        <a asp-area="Admin" asp-controller="Shelter" asp-action="Delete"
                                           asp-route-id="@shelter.Id"
                                           asp-route-returnUrl="@Context.Request.QueryString.Value"
                                           class="btn btn-danger btn-sm">Delete</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <button type="submit" form="filterForm" name="page" value="1" class="page-link">First</button>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <button type="submit" form="filterForm" name="page" value="@i" class="page-link">@i</button>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <button type="submit" form="filterForm" name="page" value="@Model.TotalPages" class="page-link">Last</button>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>