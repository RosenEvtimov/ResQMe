@model ResQMe.ViewModels.User.ProfileFormViewModel

<div class="container mt-4" style="max-width:600px;">
    <h2 class="fw-bold mb-4">Profile details</h2>

    @if (TempData["ProfileSuccess"] != null)
    {
        <div class="alert alert-success">@TempData["ProfileSuccess"]</div>
    }

    <div class="card card-static p-4">
        <div class="row mb-2">
            <div class="col-5 fw-bold text-muted">First Name</div>
            <div class="col-7">@Model.FirstName</div>
        </div>
        <div class="row mb-2">
            <div class="col-5 fw-bold text-muted">Last Name</div>
            <div class="col-7">@Model.LastName</div>
        </div>
        <div class="row mb-2">
            <div class="col-5 fw-bold text-muted">Address</div>
            <div class="col-7">@Model.Address</div>
        </div>
        <div class="row mb-2">
            <div class="col-5 fw-bold text-muted">City</div>
            <div class="col-7">@Model.City</div>
        </div>
        <div class="row mb-2">
            <div class="col-5 fw-bold text-muted">Phone</div>
            <div class="col-7">@Model.PhoneNumber</div>
        </div>
        <div class="row mb-2">
            <div class="col-5 fw-bold text-muted">Email</div>
            <div class="col-7">@Model.Email</div>
        </div>
        <div class="mt-4">
            <a asp-action="Edit" class="btn btn-primary">Edit Profile</a>
        </div>
    </div>
</div>