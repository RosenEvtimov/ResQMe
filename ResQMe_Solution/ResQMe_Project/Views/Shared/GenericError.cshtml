@{
    var code = ViewBag.StatusCode ?? 0;
    ViewData["Title"] = $"Error {code}";
}

<div class="container text-center mt-5">
    <h1 class="display-4">Error @code</h1>
    <p class="lead">An error occurred (status code @code).</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">Return to home</a>
</div>