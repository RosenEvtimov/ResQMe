@model ResQMe.ViewModels.AdoptionRequest.AdoptionRequestFormViewModel

<div class="container mt-4" style="max-width:600px;">
    <h2 class="fw-bold mb-4">🐾 Send Adoption Request</h2>
    <div class="card card-static p-4">
        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="AnimalId" />
            <input type="hidden" asp-for="ReturnUrl" />
            <input type="hidden" asp-for="ShelterReturnUrl" />
            <input type="hidden" asp-for="FromShelterId" />

            <div class="mb-3">
                <label class="form-label fw-bold">Previous adoption experience</label>
                <select asp-for="PreviousAdoptionExperience"
                        asp-items="Html.GetEnumSelectList<ResQMe.Data.Models.Enums.PreviousAdoptionExperience>()"
                        class="form-control">
                    <option value="">-- Please Select Your Experience Level --</option>
                </select>
                <span asp-validation-for="PreviousAdoptionExperience" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold" asp-for="Message">Message</label>
                <textarea asp-for="Message" class="form-control"
                          placeholder="Tell us a little about yourself and why you'd like to adopt..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Send Request</button>
                <a asp-area=""
                   asp-controller="Animal"
                   asp-action="Details"
                   asp-route-id="@Model.AnimalId"
                   asp-route-returnUrl="@Model.ReturnUrl"
                   asp-route-fromShelterId="@Model.FromShelterId"
                   asp-route-shelterReturnUrl="@Model.ShelterReturnUrl"
                   class="btn btn-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}