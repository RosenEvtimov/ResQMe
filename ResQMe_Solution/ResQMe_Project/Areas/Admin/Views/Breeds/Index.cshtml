@using ResQMe.ViewModels.Breed
@using ResQMe.ViewModels.Common
@model PaginatedResultViewModel<BreedListViewModel>

<div class="row mt-3">

    <!-- Sidebar Filters -->
    <div class="col-md-3">
        <form method="get" id="filterForm">
            <div class="card p-3 mb-3">

                <!-- Search -->
                <div class="mb-3">
                    <label class="form-label fw-500">Search</label>
                    <input type="text"
                           name="searchTerm"
                           value="@ViewBag.SearchTerm"
                           placeholder="Search by name..."
                           class="form-control form-control-sm" />
                </div>

                <!-- Species -->
                <div class="mb-3">
                    <div class="fw-500 mb-2">Species</div>
                    @foreach (var species in (IEnumerable<ResQMe.ViewModels.Common.DropdownItemViewModel>)ViewBag.AvailableSpecies)
                    {
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="selectedSpeciesIds"
                                   value="@species.Id"
                                   id="species_@species.Id"
                                   @(((List<int>)ViewBag.SelectedSpeciesIds).Contains(species.Id) ? "checked" : "") />
                            <label class="form-check-label" for="species_@species.Id">
                                @species.Name
                            </label>
                        </div>
                    }
                </div>

                <!-- Buttons -->
                <button type="submit" class="btn btn-primary btn-sm w-100 mb-2">
                    Apply Filters
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">
                    Clear All
                </a>

            </div>
        </form>
    </div>

    <!-- Main Content -->
    <div class="col-md-9">
        <h2 class="mb-4">Breeds</h2>
        <a asp-action="Add" 
           asp-route-returnUrl="@Context.Request.QueryString.Value"
           class="btn btn-success mb-3">
            Add Breed
        </a>

        @if (!Model.Items.Any())
        {
            <div class="alert alert-info">No breeds found matching your filters.</div>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Species</th>
                        <th style="width:200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var breed in Model.Items)
                    {
                        <tr>
                            <td>@breed.Name</td>
                            <td>@breed.SpeciesName</td>
                            <td>
                                <a asp-action="Edit"
                                   asp-route-id="@breed.Id"
                                   asp-route-returnUrl="@Context.Request.QueryString.Value"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>
                                <a asp-action="Delete"
                                   asp-route-id="@breed.Id"
                                   asp-route-returnUrl="@Context.Request.QueryString.Value"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <button type="submit" form="filterForm" name="page" value="1" class="page-link">First</button>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <button type="submit" form="filterForm" name="page" value="@i" class="page-link">@i</button>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <button type="submit" form="filterForm" name="page" value="@Model.TotalPages" class="page-link">Last</button>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>