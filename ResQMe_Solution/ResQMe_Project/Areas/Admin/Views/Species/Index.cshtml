@using ResQMe.ViewModels.Species
@using ResQMe.ViewModels.Common
@model PaginatedResultViewModel<SpeciesListViewModel>

<div class="row mt-3">
    <div class="col-md-3">
        <form method="get" id="filterForm">
            <div class="card p-3 mb-3">

                <!-- Search -->
                <div class="mb-3">
                    <label class="form-label fw-500">Search</label>
                    <input type="text"
                           name="searchTerm"
                           value="@ViewBag.SearchTerm"
                           placeholder="Search by name..."
                           class="form-control form-control-sm" />
                </div>

                <!-- Buttons -->
                <button type="submit" class="btn btn-primary btn-sm w-100 mb-2">
                    Search
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">
                    Clear
                </a>
            </div>
        </form>
    </div>

    <!-- Main content -->
    <div class="col-md-9">
        <h2 class="mb-4">Species</h2>
        <a asp-action="Add"
           asp-route-returnUrl="@Context.Request.QueryString.Value"
           class="btn btn-success mb-3">
            Add Species
        </a>

        @if (!Model.Items.Any())
        {
            <div class="alert alert-info">No species found matching your search.</div>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th style="width:200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var species in Model.Items)
                    {
                        <tr>
                            <td>@species.Name</td>
                            <td>
                                <a asp-action="Edit"
                                   asp-route-id="@species.Id"
                                   asp-route-returnUrl="@Context.Request.QueryString.Value"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>
                                <a asp-action="Delete"
                                   asp-route-id="@species.Id"
                                   asp-route-returnUrl="@Context.Request.QueryString.Value"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <button type="submit" form="filterForm" name="page" value="1" class="page-link">First</button>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <button type="submit" form="filterForm" name="page" value="@i" class="page-link">@i</button>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <button type="submit" form="filterForm" name="page" value="@Model.TotalPages" class="page-link">Last</button>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>